# Dafny Verification Benchmark -- Configuration File
#
# Copy this file to config.yaml and adjust to your setup.
#
# Usage:
#   python run_benchmark.py --config config.yaml
#   python parallel_runner.py --config config.yaml
#
# CLI flags override values from this file.

# ── Adapter ──────────────────────────────────────────────────────────
# Options: claude_code, manual, openai_compatible, hf_transformers
adapter: openai_compatible

# ── Model (adapter-specific) ────────────────────────────────────────
model: meta-llama/Llama-3.1-70B-Instruct

# For openai_compatible adapter:
base_url: http://localhost:8000/v1
# api_key: sk-...           # optional; defaults to OPENAI_API_KEY env var

# For hf_transformers adapter:
# model_path: meta-llama/Llama-3.1-8B-Instruct
# device: auto               # "auto" for multi-GPU, "cuda:0" for single GPU

# ── Benchmark settings ──────────────────────────────────────────────
max_iterations: 20           # max dafny verify calls per problem
timeout: 600                 # seconds per problem

# ── Parallel execution ──────────────────────────────────────────────
parallel_workers: 8          # number of concurrent problems

# ── Paths ────────────────────────────────────────────────────────────
dafny_path: /opt/homebrew/Cellar/dotnet@8/8.0.124/libexec/dotnet /Users/mchiesa/work/projects/2026-02-dafny-liftings/dafny-source/Binaries/Dafny.dll
problems_dir: dataset/problems
output_dir: results/

# ── Optional: restrict to specific problems ──────────────────────────
# problems:
#   - sum_array
#   - reverse_array
