method Pow2(exp: int) returns (result: int)
{
  result := 1;
  var i := 0;
  while i < exp
  {
    result := result * 2;
    i := i + 1;
  }
}

method PhoenixAndBalance(n: int) returns (diff: int)
{
  var totalVal := Pow2(n + 1);
  totalVal := totalVal - 2;
  var halfPow := Pow2(n / 2);
  var nPow := Pow2(n);
  var left := halfPow - 2 + nPow;
  var right := totalVal - left;
  diff := left - right;
}

method Main()
{
  // Test 1: T=2
  var inputs1 := [2, 4];
  var expected1 := [2, 6];
  var i := 0;
  while i < |inputs1|
