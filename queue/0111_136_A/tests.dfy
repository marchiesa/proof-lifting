function GaveTo(giver: int, p: seq<int>): int
  requires 1 <= giver <= |p|
{
  p[giver - 1]
}

predicate ValidGiftExchange(n: int, p: seq<int>)
{
  n >= 0 &&
  |p| == n &&
  (forall i | 0 <= i < n :: 1 <= p[i] <= n) &&
  (forall i, j | 0 <= i < n && 0 <= j < n && i != j :: p[i] != p[j])
}

predicate CorrectAnswer(n: int, p: seq<int>, b: seq<int>)
  requires ValidGiftExchange(n, p)
{
  |b| == n &&
  (forall j | 0 <= j < n :: 1 <= b[j] <= n && GaveTo(b[j], p) == j + 1)
}

method Presents(n: int, p: seq<int>) returns (b: seq<int>)
  requires ValidGiftExchange(n, p)
  ensures CorrectAnswer(n, p, b)
{
  b := seq(n, _ => 0);
  var i := 0;
  while i < |p|
  {
    b := b[p[i] - 1 := i + 1];
    i := i + 1;
  }
}

method Main()
{
  // === SPEC POSITIVE TESTS ===
  // Using small inputs (n<=5) to keep bounded quantifier evaluation fast
  expect CorrectAnswer(1, [1], [1]), "spec positive 1";
  expect CorrectAnswer(2, [1,2], [1,2]), "spec positive 2";
  expect CorrectAnswer(3, [1,3,2], [1,3,2]), "spec positive 3";
  expect CorrectAnswer(4, [2,3,4,1], [4,1,2,3]), "spec positive 4";
  expect CorrectAnswer(5, [5,4,3,2,1], [5,4,3,2,1]), "spec positive 5";

  // === SPEC NEGATIVE TESTS ===
  // Wrong outputs that CorrectAnswer must reject
  expect !CorrectAnswer(1, [1], [2]), "spec negative 1";
  expect !CorrectAnswer(2, [1,2], [2,2]), "spec negative 2";
  expect !CorrectAnswer(3, [1,3,2], [2,3,2]), "spec negative 3";
  expect !CorrectAnswer(4, [2,3,4,1], [5,1,2,3]), "spec negative 4";
  expect !CorrectAnswer(5, [5,4,3,2,1], [6,4,3,2,1]), "spec negative 5";

  // === IMPLEMENTATION TESTS ===
  var r1 := Presents(4, [2,3,4,1]);
  expect r1 == [4,1,2,3], "impl test 1 failed";

  var r2 := Presents(3, [1,3,2]);
  expect r2 == [1,3,2], "impl test 2 failed";

  var r3 := Presents(2, [1,2]);
  expect r3 == [1,2], "impl test 3 failed";

  var r4 := Presents(1, [1]);
  expect r4 == [1], "impl test 4 failed";

  var r5 := Presents(10, [1,3,2,6,4,5,7,9,8,10]);
  expect r5 == [1,3,2,5,6,4,7,9,8,10], "impl test 5 failed";

  var r6 := Presents(5, [5,4,3,2,1]);
  expect r6 == [5,4,3,2,1], "impl test 6 failed";

  var r7 := Presents(20, [2,1,4,3,6,5,8,7,10,9,12,11,14,13,16,15,18,17,20,19]);
  expect r7 == [2,1,4,3,6,5,8,7,10,9,12,11,14,13,16,15,18,17,20,19], "impl test 7 failed";

  var r8 := Presents(21, [3,2,1,6,5,4,9,8,7,12,11,10,15,14,13,18,17,16,21,20,19]);
  expect r8 == [3,2,1,6,5,4,9,8,7,12,11,10,15,14,13,18,17,16,21,20,19], "impl test 8 failed";

  var r9 := Presents(10, [3,4,5,6,7,8,9,10,1,2]);
  expect r9 == [9,10,1,2,3,4,5,6,7,8], "impl test 9 failed";

  var r10 := Presents(8, [1,5,3,7,2,6,4,8]);
  expect r10 == [1,5,3,7,2,6,4,8], "impl test 10 failed";

  var r11 := Presents(50, [49,22,4,2,20,46,7,32,5,19,48,24,26,15,45,21,44,11,50,43,39,17,31,1,42,34,3,27,36,25,12,30,13,33,28,35,18,6,8,37,38,14,10,9,29,16,40,23,41,47]);
  expect r11 == [24,4,27,3,9,38,7,39,44,43,18,31,33,42,14,46,22,37,10,5,16,2,48,12,30,13,28,35,45,32,23,8,34,26,36,29,40,41,21,47,49,25,20,17,15,6,50,11,1,19], "impl test 11 failed";

  var r12 := Presents(34, [13,20,33,30,15,11,27,4,8,2,29,25,24,7,3,22,18,10,26,16,5,1,32,9,34,6,12,14,28,19,31,21,23,17]);
  expect r12 == [22,10,15,8,21,26,14,9,24,18,6,27,1,28,5,20,34,17,30,2,32,16,33,13,12,19,7,29,11,4,31,23,3,25], "impl test 12 failed";

  var r13 := Presents(92, [23,1,6,4,84,54,44,76,63,34,61,20,48,13,28,78,26,46,90,72,24,55,91,89,53,38,82,5,79,92,29,32,15,64,11,88,60,70,7,66,18,59,8,57,19,16,42,21,80,71,62,27,75,86,36,9,83,73,74,50,43,31,56,30,17,33,40,81,49,12,10,41,22,77,25,68,51,2,47,3,58,69,87,67,39,37,35,65,14,45,52,85]);
  expect r13 == [2,78,80,4,28,3,39,43,56,71,35,70,14,89,33,46,65,41,45,12,48,73,1,21,75,17,52,15,31,64,62,32,66,10,87,55,86,26,85,67,72,47,61,7,90,18,79,13,69,60,77,91,25,6,22,63,44,81,42,37,11,51,9,34,88,40,84,76,82,38,50,20,58,59,53,8,74,16,29,49,68,27,57,5,92,54,83,36,24,19,23,30], "impl test 13 failed";

  var r14 := Presents(49, [30,24,33,48,7,3,17,2,8,35,10,39,23,40,46,32,18,21,26,22,1,16,47,45,41,28,31,6,12,43,27,11,13,37,19,15,44,5,29,42,4,38,20,34,14,9,25,36,49]);
  expect r14 == [21,8,6,41,38,28,5,9,46,11,32,29,33,45,36,22,7,17,35,43,18,20,13,2,47,19,31,26,39,1,27,16,3,44,10,48,34,42,12,14,25,40,30,37,24,15,23,4,49], "impl test 14 failed";

  var r15 := Presents(12, [3,8,7,4,6,5,2,1,11,9,10,12]);
  expect r15 == [8,7,1,4,6,5,3,2,10,11,9,12], "impl test 15 failed";

  var r16 := Presents(78, [16,56,36,78,21,14,9,77,26,57,70,61,41,47,18,44,5,31,50,74,65,52,6,39,22,62,67,69,43,7,64,29,24,40,48,51,73,54,72,12,19,34,4,25,55,33,17,35,23,53,10,8,27,32,42,68,20,63,3,2,1,71,58,46,13,30,49,11,37,66,38,60,28,75,15,59,45,76]);
  expect r16 == [61,60,59,43,17,23,30,52,7,51,68,40,65,6,75,1,47,15,41,57,5,25,49,33,44,9,53,29,32,66,18,54,46,42,48,3,69,71,24,34,13,55,50,16,77,64,14,35,67,19,36,22,50,38,45,2,10,63,76,72,12,26,58,31,21,70,27,56,28,11,62,39,37,20,74,78,8,4], "impl test 16 failed";

  var r17 := Presents(64, [64,57,40,3,15,8,62,18,33,59,51,19,22,13,4,37,47,45,50,35,63,11,58,42,46,21,7,2,41,48,32,23,28,38,17,12,24,27,49,31,60,6,30,25,61,52,26,54,9,14,29,20,44,39,55,10,34,16,5,56,1,36,53,43]);
