  var r18 := Presents(49, [38,20,49,32,14,41,39,45,25,48,40,19,26,43,34,12,10,3,35,42,5,7,46,47,4,2,13,22,16,24,33,15,11,18,29,31,23,9,44,36,6,17,37,1,30,28,8,21,27]);
  expect r18 == [44,26,18,25,21,41,22,47,38,17,33,16,27,5,32,29,42,34,12,2,48,28,37,30,9,13,49,46,35,45,36,4,31,15,19,40,43,1,7,11,6,20,14,39,8,23,24,10,3], "impl test 18 failed";

  var r19 := Presents(78, [17,50,30,48,33,12,42,4,18,53,76,67,38,3,20,72,51,55,60,63,46,10,57,45,54,32,24,62,8,11,35,44,65,74,58,28,2,6,56,52,39,23,47,49,61,1,66,41,15,77,7,27,78,13,14,34,5,31,37,21,40,16,29,69,59,43,64,36,70,19,25,73,71,75,9,68,26,22]);
  expect r19 == [46,37,14,8,57,38,51,29,75,22,30,6,54,55,49,62,1,9,70,15,60,78,42,27,71,77,52,36,63,3,58,26,5,56,31,68,59,13,41,61,48,7,66,32,24,21,43,4,44,2,17,40,10,25,18,39,23,35,65,19,45,28,20,67,33,47,12,76,64,69,73,16,72,34,74,11,50,53], "impl test 19 failed";

  var r20 := Presents(29, [14,21,27,1,4,18,10,17,20,23,2,24,7,9,28,22,8,25,12,15,11,6,16,29,3,26,19,5,13]);
  expect r20 == [4,11,25,5,28,22,13,17,14,7,21,19,29,1,20,23,8,6,27,9,2,16,10,12,18,26,3,15,24], "impl test 20 failed";

  print "All tests passed\n";
}