  expect c == [1, 2, 4, 5, 6, 7, 10, 11, 13, 14, 15, 17, 20, 22, 23, 24, 27, 30, 31, 32, 33, 34, 38, 39, 40, 41, 42, 46, 47, 49, 50, 51, 52, 53, 57, 58, 59, 62, 64, 65, 66, 67, 68, 69, 70, 71, 72, 76, 79, 81, 82, 83, 84, 86, 87, 89, 91, 92, 94, 95, 96, 97, 98, 99], "Test 17: coalition mismatch";

  // Test 18
  k, c := PrimeMinister(100, [100, 32, 29, 63, 31, 41, 29, 59, 35, 34, 62, 60, 32, 38, 60, 32, 29, 43, 42, 62, 61, 27, 30, 49, 44, 54, 65, 51, 37, 35, 31, 54, 55, 25, 59, 29, 45, 59, 50, 57, 63, 61, 52, 57, 56, 63, 35, 33, 27, 58, 59, 60, 59, 60, 54, 48, 26, 50, 29, 27, 45, 60, 37, 28, 52, 53, 62, 40, 34, 56, 51, 45, 30, 43, 64, 27, 29, 33, 33, 62, 44, 53, 37, 62, 55, 55, 55, 48, 31, 62, 31, 31, 29, 59, 37, 29, 31, 65, 33, 52]);
