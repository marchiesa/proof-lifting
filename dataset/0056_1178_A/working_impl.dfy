  // Test 19
  k, c := PrimeMinister(100, [100, 35, 48, 52, 55, 45, 61, 39, 44, 45, 36, 49, 64, 51, 32, 61, 55, 34, 55, 42, 30, 63, 28, 28, 35, 46, 58, 36, 61, 58, 48, 29, 46, 26, 61, 56, 60, 36, 56, 30, 53, 50, 30, 63, 49, 66, 35, 42, 55, 53, 31, 66, 45, 54, 36, 37, 52, 57, 30, 37, 45, 29, 44, 38, 43, 30, 31, 42, 35, 35, 64, 59, 34, 26, 58, 59, 46, 47, 30, 66, 55, 34, 34, 44, 53, 30, 55, 38, 36, 28, 65, 32, 31, 61, 65, 58, 52, 49, 40, 52]);
