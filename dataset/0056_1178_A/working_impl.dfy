  expect k == 0, "Test 6: k mismatch";

  // Test 7
  k, c := PrimeMinister(2, [1, 1]);
  expect k == 0, "Test 7: k mismatch";

  // Test 8
  k, c := PrimeMinister(4, [50, 25, 25, 100]);
  expect k == 0, "Test 8: k mismatch";

  // Test 9
  k, c := PrimeMinister(3, [51, 26, 26]);
  expect k == 0, "Test 9: k mismatch";

  // Test 10
  k, c := PrimeMinister(3, [1, 1, 1]);
  expect k == 0, "Test 10: k mismatch";

  // Test 11
  k, c := PrimeMinister(3, [2, 1, 1]);
  expect k == 3, "Test 11: k mismatch";
  expect c == [1, 2, 3], "Test 11: coalition mismatch";

  // Test 12
  k, c := PrimeMinister(4, [2, 1, 1, 1]);
  expect k == 4, "Test 12: k mismatch";
  expect c == [1, 2, 3, 4], "Test 12: coalition mismatch";

  // Test 13
