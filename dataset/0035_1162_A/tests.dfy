// Spec predicates and functions
predicate IsValidAssignment(a: seq<int>, n: int, h: int, restrictions: seq<(int, int, int)>)
  requires n >= 0
{
  |a| == n &&
  (forall i | 0 <= i < n :: 0 <= a[i] <= h) &&
  (forall k | 0 <= k < |restrictions| ::
    forall j | restrictions[k].0 - 1 <= j < restrictions[k].1 ::
      0 <= j < n ==> a[j] <= restrictions[k].2)
}

function Profit(a: seq<int>): int
  decreases |a|
{
  if |a| == 0 then 0
  else Profit(a[..|a|-1]) + a[|a|-1] * a[|a|-1]
}

function EffectiveCap(i: int, h: int, restrictions: seq<(int, int, int)>): int
  decreases |restrictions|
{
  if |restrictions| == 0 then h
  else
    var prev := EffectiveCap(i, h, restrictions[..|restrictions|-1]);
    var r := restrictions[|restrictions|-1];
    if r.0 - 1 <= i < r.1 && r.2 < prev then r.2
    else prev
}

function OptimalAssignment(n: int, h: int, restrictions: seq<(int, int, int)>): seq<int>
  requires n >= 0
  decreases n
{
  if n == 0 then []
  else OptimalAssignment(n - 1, h, restrictions) + [EffectiveCap(n - 1, h, restrictions)]
}

method ZoningRestrictions(n: int, h: int, m: int, restrictions: seq<(int, int, int)>) returns (maxProfit: int)
  requires n >= 0
  requires h >= 0
  requires forall k | 0 <= k < |restrictions| ::
    1 <= restrictions[k].0 <= restrictions[k].1 <= n && restrictions[k].2 >= 0
  ensures IsValidAssignment(OptimalAssignment(n, h, restrictions), n, h, restrictions)
  ensures maxProfit == Profit(OptimalAssignment(n, h, restrictions))
  ensures forall i | 0 <= i < n ::
    forall v | 0 <= v <= h ::
      (forall k | 0 <= k < |restrictions| ::
        restrictions[k].0 - 1 <= i < restrictions[k].1 ==> v <= restrictions[k].2)
      ==> v <= EffectiveCap(i, h, restrictions)
{
  var ans := new int[n];
  var i := 0;
  while i < n {
    ans[i] := h;
    i := i + 1;
  }

  i := 0;
  while i < |restrictions| {
    var l := restrictions[i].0;
    var r := restrictions[i].1;
    var x := restrictions[i].2;
    var j := l - 1;
    while j < r {
      if ans[j] > x {
        ans[j] := x;
      }
      j := j + 1;
    }
    i := i + 1;
  }

  var temp := 0;
  i := 0;
  while i < n {
    temp := temp + ans[i] * ans[i];
    i := i + 1;
  }
  maxProfit := temp;
}

method Main()
{
  // ==========================================
  // SPEC POSITIVE TESTS (small inputs)
  // ==========================================

  // Spec positive 1: from Test 1 (n=3, h=3) — heights [1,3,2], profit=1+9+4=14
  var sp1 := OptimalAssignment(3, 3, [(1,1,1),(2,2,3),(3,3,2)]);
  expect IsValidAssignment(sp1, 3, 3, [(1,1,1),(2,2,3),(3,3,2)]), "spec positive 1 validity";
  expect Profit(sp1) == 14, "spec positive 1";

  // Spec positive 2: n=1, h=3, no restrictions — height [3], profit=9
  var sp2 := OptimalAssignment(1, 3, []);
  expect IsValidAssignment(sp2, 1, 3, []), "spec positive 2 validity";
  expect Profit(sp2) == 9, "spec positive 2";

  // Spec positive 3: n=1, h=5, cap at 2 — height [2], profit=4
  var sp3 := OptimalAssignment(1, 5, [(1,1,2)]);
  expect IsValidAssignment(sp3, 1, 5, [(1,1,2)]), "spec positive 3 validity";
  expect Profit(sp3) == 4, "spec positive 3";

  // Spec positive 4: n=2, h=3, no restrictions — heights [3,3], profit=18
  var sp4 := OptimalAssignment(2, 3, []);
  expect IsValidAssignment(sp4, 2, 3, []), "spec positive 4 validity";
  expect Profit(sp4) == 18, "spec positive 4";

  // Spec positive 5: n=2, h=4, full cap at 2 — heights [2,2], profit=8
  var sp5 := OptimalAssignment(2, 4, [(1,2,2)]);
  expect IsValidAssignment(sp5, 2, 4, [(1,2,2)]), "spec positive 5 validity";
  expect Profit(sp5) == 8, "spec positive 5";

  // Spec positive 6: n=3, h=5, all capped at 0 (scaled Test 3) — profit=0
  var sp6 := OptimalAssignment(3, 5, [(1,3,0)]);
  expect IsValidAssignment(sp6, 3, 5, [(1,3,0)]), "spec positive 6 validity";
  expect Profit(sp6) == 0, "spec positive 6";

  // Spec positive 7: n=2, h=4, two restrictions — heights [2,3], profit=13
  var sp7 := OptimalAssignment(2, 4, [(1,1,2),(2,2,3)]);
  expect IsValidAssignment(sp7, 2, 4, [(1,1,2),(2,2,3)]), "spec positive 7 validity";
  expect Profit(sp7) == 13, "spec positive 7";

  // Spec positive 8: n=3, h=2, partial restriction — heights [2,1,1], profit=6
  var sp8 := OptimalAssignment(3, 2, [(2,3,1)]);
  expect IsValidAssignment(sp8, 3, 2, [(2,3,1)]), "spec positive 8 validity";
  expect Profit(sp8) == 6, "spec positive 8";

  // Spec positive 9: n=1, h=0 — height [0], profit=0
  var sp9 := OptimalAssignment(1, 0, []);
  expect IsValidAssignment(sp9, 1, 0, []), "spec positive 9 validity";
  expect Profit(sp9) == 0, "spec positive 9";

  // Spec positive 10: n=0, h=5 — empty, profit=0
  var sp10 := OptimalAssignment(0, 5, []);
  expect IsValidAssignment(sp10, 0, 5, []), "spec positive 10 validity";
  expect Profit(sp10) == 0, "spec positive 10";

  // ==========================================
  // SPEC NEGATIVE TESTS (small inputs)
  // ==========================================

  // Spec negative 1: from Neg 1 (n=3, h=3, wrong=15, correct=14)
  expect Profit(OptimalAssignment(3, 3, [(1,1,1),(2,2,3),(3,3,2)])) != 15, "spec negative 1";

  // Spec negative 2: n=1, h=3, wrong=10, correct=9
  expect Profit(OptimalAssignment(1, 3, [])) != 10, "spec negative 2";

  // Spec negative 3: n=3, h=5, all capped 0, wrong=1, correct=0 (scaled Neg 3)
  expect Profit(OptimalAssignment(3, 5, [(1,3,0)])) != 1, "spec negative 3";

  // Spec negative 4: n=2, h=4, cap at 2, wrong=9, correct=8
  expect Profit(OptimalAssignment(2, 4, [(1,2,2)])) != 9, "spec negative 4";

  // Spec negative 5: n=2, h=4, two restrictions, wrong=14, correct=13
  expect Profit(OptimalAssignment(2, 4, [(1,1,2),(2,2,3)])) != 14, "spec negative 5";

  // Spec negative 6: n=0, h=5, wrong=1, correct=0
  expect Profit(OptimalAssignment(0, 5, [])) != 1, "spec negative 6";

  // Spec negative 7: n=2, h=3, no restrictions, wrong=19, correct=18
  expect Profit(OptimalAssignment(2, 3, [])) != 19, "spec negative 7";

  // Spec negative 8: n=3, h=2, partial restriction, wrong=7, correct=6
  expect Profit(OptimalAssignment(3, 2, [(2,3,1)])) != 7, "spec negative 8";

  // Spec negative 9: n=1, h=5, cap at 2, wrong=5, correct=4
  expect Profit(OptimalAssignment(1, 5, [(1,1,2)])) != 5, "spec negative 9";

  // Spec negative 10: n=1, h=0, wrong=1, correct=0
  expect Profit(OptimalAssignment(1, 0, [])) != 1, "spec negative 10";

