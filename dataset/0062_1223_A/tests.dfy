predicate IsValidCME(a: int, b: int, c: int)
{
  a >= 1 && b >= 1 && c >= 1 && a + b == c
}

predicate CanFormCMEWithMatches(total: int)
{
  exists a | 1 <= a <= total / 2 - 1 ::
    var b := total / 2 - a;
    IsValidCME(a, b, a + b) && a + b + (a + b) == total
}

// Top-level ensures conjunction for spec testing
predicate CMEPostcondition(n: int, extra: int)
{
  extra >= 0 &&
  CanFormCMEWithMatches(n + extra) &&
  forall e | 0 <= e < extra :: !CanFormCMEWithMatches(n + e)
}

method CME(n: int) returns (extra: int)
  ensures extra >= 0
  ensures CanFormCMEWithMatches(n + extra)
  ensures forall e | 0 <= e < extra :: !CanFormCMEWithMatches(n + e)
{
  if n < 4 {
    extra := 4 - n;
  } else {
    extra := n % 2;
  }
}

