method PileOfStones(s: seq<char>) returns (result: int)
{
  result := 0;
  var i := 0;
  while i < |s|
  {
    if s[i] == '-' {
      if result > 0 {
        result := result - 1;
      }
    } else {
      result := result + 1;
    }
    i := i + 1;
  }
}

method Main()
{
  var r: int;

  // Test 1
  r := PileOfStones("---");
  expect r == 0, "Test 1 failed";

  // Test 2
  r := PileOfStones("++++");
  expect r == 4, "Test 2 failed";

  // Test 3
  r := PileOfStones("-+");
  expect r == 1, "Test 3 failed";

  // Test 4
  r := PileOfStones("++-++");
  expect r == 3, "Test 4 failed";

  // Test 5
  r := PileOfStones("+");
  expect r == 1, "Test 5 failed";

  // Test 6
  r := PileOfStones("++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++");
  expect r == 100, "Test 6 failed";

  // Test 7
  r := PileOfStones("----------------------------------------------------------------------------------------------------");
  expect r == 0, "Test 7 failed";

  // Test 8
  r := PileOfStones("-+-+-+-+-+-+-+-+-+-+-+-+-+-+++++++++++++++-++++++++++++++++++++++++++++++++++-++++++++++++++++++++++");
  expect r == 69, "Test 8 failed";

  // Test 9
  r := PileOfStones("+-+-+-++--++-++-+-+---+--++++++-++++--++-++---+--++++--+++++++-++-+--+-+-+--+-+++++-+--+---+-++-++-+");
  expect r == 17, "Test 9 failed";

  // Test 10
  r := PileOfStones("++-+-+-+-+++-++++--+++----+-+-+-------+-+-++--++--+-+++++---+-++---++-+-++---+--+-+-++-++-+---++-+--");
  expect r == 0, "Test 10 failed";

  // Test 11
  r := PileOfStones("+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-");
  expect r == 0, "Test 11 failed";

  // Test 12
  r := PileOfStones("--+++++++++++++++++++++++++++++++++++++++++++++++++------------------------------------------------");
  expect r == 1, "Test 12 failed";

  // Test 13
  r := PileOfStones("+-----+-++++----++-+--+-+++-++--+--++---++++----+-+++--+++--+---++--++--++-+--+-+-+-+-+-+-+-++-+--+-");
  expect r == 0, "Test 13 failed";

  // Test 14
  r := PileOfStones("+++++--+-+++-+-++---+-++-+---++-------++-+--+-++-+--+-+--+-+-+----++-+-----++----++++-+-+---+--+--+-");
  expect r == 0, "Test 14 failed";

  // Test 15
  r := PileOfStones("-------+-++-------------+-----+--+----++----+-----+----+-----++-------------------+-+-------+-------");
  expect r == 0, "Test 15 failed";

  // Test 16
  r := PileOfStones("-+--+-++--+-+-+-+-+-+-+-+-++--++--+-+-+-+-+-+-+-+-+-+-+-++--+-+-+-+-+-+-+-++--+-+-+-+-+-+-+-+-+-+-+-");
  expect r == 0, "Test 16 failed";

  // Test 17
  r := PileOfStones("+-++--+-+-++--++-+++-++++----+--+---+-+-+-+-++--+-+-+-+-+-+-++--+-+-+-+-+-+-+-+++---+++-+-+-+---++--");
  expect r == 0, "Test 17 failed";

  // Test 18
  r := PileOfStones("-++------+---++++-+---++---+--+-++--+-+-++--+-+-++++-+++-+-----++-+--++-+++++---+-----+++---+-+-+-+-");
  expect r == 0, "Test 18 failed";

  // Test 19
  r := PileOfStones("------+---+--------+++--+--------------++--+----------+-+---+------+-+-----++---+------+-+---++-+---");
  expect r == 0, "Test 19 failed";

  // Test 20
  r := PileOfStones("-+--+++-++-+-+--++-++-------+-++--++----+--++-++------++--+++-+-+-+--+++---+----+--+++++-++----+---+");
  expect r == 1, "Test 20 failed";

  print "All tests passed\n";
}